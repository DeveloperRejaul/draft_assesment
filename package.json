{
  "name": "TaskManagerAssessmentApp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "android-build-apk": "cd android && ./gradlew assembleRelease && cd ..",
    "android-build-abb": "cd android && ./gradlew bundleRelease && cd ..",
    "crate-esa": "eas build:configure",
    "build-android-apk": "eas build --platform android --profile preview",
    "build-ios": "eas build --platform ios",
    "build-android-abb": "eas build --platform android --profile release",
    "expo-account": "npx expo whoami",
    "ssh-add": "ssh-add ~/.ssh/id_ed25519",
    "adb-connect": "adb connect",
    "adb disconnect": "adb disconnect"
  },
